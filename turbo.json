{
  "$schema": "https://turborepo.com/schema.json",
  "tasks": {
    "//#build:icons": {
      "inputs": [
        "$TURBO_ROOT$/icons/**/*.svg",
        "$TURBO_ROOT$/keywords.json",
        "$TURBO_ROOT$/script/build.cjs"
      ],
      "outputs": [
        "$TURBO_ROOT$/packages/build/data.json",
        "$TURBO_ROOT$/packages/build/svg/**"
      ]
    },
    "//#lint:root": {
      "outputs": []
    },
    "build": {
      "dependsOn": ["//#build:icons", "^build"],
      "outputs": ["build/**", "dist/**", "src/__generated__/**"]
    },
    "lint": {
      "outputs": []
    },
    "ts-test": {
      "dependsOn": ["build"],
      "outputs": []
    }
  }
}
